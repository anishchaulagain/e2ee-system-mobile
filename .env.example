# Override the API/socket URL the mobile app talks to.
# Defaults from app.json (extra.apiUrl) are used if these are unset.
#
# Pointing the app at a backend running on your dev machine:
#   - iOS Simulator:        http://localhost:3000
#   - Android emulator:     http://10.0.2.2:3000
#   - Physical device:      http://<your-lan-ip>:3000  (same Wi-Fi as your computer)
#
# Don't quote the values — Expo passes them through verbatim.
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000
